#!/bin/bash
#SBATCH --job-name=manipulation-eval-suites
#SBATCH --output=/work/rleap1/daniel.swoboda/slurm/eval-suites_%j.out
#SBATCH --error=/work/rleap1/daniel.swoboda/slurm/eval-suites_%j.err
#SBATCH --time=02:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=8G
#SBATCH --partition=rleap_gpu_24gb
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=daniel.swoboda@ml.rwth-aachen.de

set -euo pipefail

REPO_ROOT="/work/rleap1/daniel.swoboda/projects/manipulation"
cd "$REPO_ROOT"

# Source validation split generated by generate_data.sbatch.
SOURCE_VAL="${SOURCE_VAL:-/work/rleap1/daniel.swoboda/projects/manipulation/datasets/tabletop/validation}"

# Output directory where suite folders will be created.
SUITES_OUT="${SUITES_OUT:-/work/rleap1/daniel.swoboda/projects/manipulation/datasets/eval_suites}"

# Number of examples per suite.
PER_SUITE="${PER_SUITE:-20}"

# Optional small-grid validation source for val_small_grid.
# Leave empty to skip val_small_grid creation.
SMALL_GRID_SOURCE="${SMALL_GRID_SOURCE:-}"

CMD=(
  python "$REPO_ROOT/scripts/build_eval_suites.py"
  --source "$SOURCE_VAL"
  --output_root "$SUITES_OUT"
  --per_suite "$PER_SUITE"
)

if [[ -n "${SMALL_GRID_SOURCE}" && -d "${SMALL_GRID_SOURCE}" ]]; then
  CMD+=(--small_grid_source "$SMALL_GRID_SOURCE")
else
  echo "SMALL_GRID_SOURCE missing or empty; val_small_grid will be skipped."
fi

echo "Running:"
printf ' %q' "${CMD[@]}"
echo

"${CMD[@]}"
