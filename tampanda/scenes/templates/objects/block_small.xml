<body pos="0 0 0">
  <joint name="_freejoint" type="free"/>
  <!-- 4cm cube: mass=0.064 kg -->
  <inertial mass="0.064" pos="0 0 0" diaginertia="0.0001 0.0001 0.0001"/>
  <!-- friction: sliding 1.0 (wood-on-wood, MuJoCo default), torsional 0.05
       (10× default — resists block spinning during gripper release),
       rolling 0.001. condim=4 enables torsional friction in the contact
       solver so the value is actually consumed. Reduces post-release slip
       in `on(small, medium)` stacks where the placement margin is ~5mm. -->
  <geom name="_geom" type="box" size="0.02 0.02 0.02" rgba="0.8 0.2 0.2 1"
        solimp="0.99 0.99 0.01" solref="0.02 1"
        friction="1.0 0.05 0.001" condim="4"/>
</body>
